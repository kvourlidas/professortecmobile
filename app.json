{
  "expo": {
    "name": "Edra",
    "slug": "professortec-mobile",
    "version": "1.0.0",
    "owner": "nvourlidas",
    "orientation": "portrait",
    "icon": "./assets/images/edra-primary-dark.png",
    "scheme": "edra",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nvourlidas.edra",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "package": "com.nvourlidas.edra",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/edra-primary-dark.png",
        "backgroundImage": "./assets/images/edra-primary-dark.png",
        "monochromeImage": "./assets/images/edra-primary-dark.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/edra-primary-dark.png",
          "color": "#E6F4FE",
          "androidMode": "default"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/edra-primary-transparent-dark(PNG).png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fac90460-3320-41f7-8e25-f7bab914a64b"
      }
    }
  }
}
